  leftSpeaker: {fileID: 11400000, guid: 6c66cb74443ba4f48997c550697b1a3c, type: 2}
  rightSpeaker: {fileID: 11400000, guid: 1020b560f53d0c14391b21ddb8f92c1c, type: 2}
  dialogueLines:
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Lazy no good residents... always wanting affordable housing.
  - speakerSideToHighlight: 1
    expression: 0
    dialogueText: Something wrong, sir?
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Yes, there is. And I want you to do something about it.
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Could you carry these "flyers" to the post office?
  - speakerSideToHighlight: 1
    expression: 0
    dialogueText: Well, I don't think I actually am able to do that right now. Maybe
      later?
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: god damn it...
