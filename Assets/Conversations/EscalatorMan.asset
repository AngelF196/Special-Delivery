MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bcf5a6b18d80e164d9184d038e6f3df5, type: 3}
  m_Name: EscalatorMan
  m_EditorClassIdentifier: 
  leftSpeaker: {fileID: 11400000, guid: 29cef826212065940ad652a7cba88882, type: 2}
  rightSpeaker: {fileID: 11400000, guid: 1020b560f53d0c14391b21ddb8f92c1c, type: 2}
  dialogueLines:
  - speakerSideToHighlight: 1
    expression: 0
    dialogueText: Heya! You need a package to deliver?
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Nah, I just wanna run up this escalator to get some cardio in.
  - speakerSideToHighlight: 1
    expression: 2
    dialogueText: But isn't there a gym for you to do that?
  - speakerSideToHighlight: 0
    expression: 1
    dialogueText: Last time I went in there, some asshole dropped a dumbbell on my
      head without any warning... what I was able to hear before passing out was
      the sound of cheering.
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Haven't gone back to that place ever since, so I've resorted to
      this escalator.
  - speakerSideToHighlight: 1
    expression: 0
    dialogueText: I am so sorry that this happened to you. Anything I can do?
  - speakerSideToHighlight: 0
    expression: 0
    dialogueText: Nah, nothing you need to do. Other than to ^^STOP TALKING TO ME!!^^
      I'm locking in for a marathon!
